# ─────────────────────────────────────────────
# CCXT Exchange (default is kraken)
# Any CCXT-supported exchange (binance, coinbase, etc.)
# ─────────────────────────────────────────────
CCXT_EXCHANGE=kraken

# ─────────────────────────────────────────────
# API Keys for *scan APIs (to fetch balances)
# Get free API keys from:
# - Ethereum:  https://etherscan.io/myapikey
# - Polygon:   https://polygonscan.com/myapikey
# - Optimism:  https://optimistic.etherscan.io/myapikey
# - Arbitrum:  https://arbiscan.io/myapikey
# - Base:  https://basescan.org/myapikey
# ─────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_key_here
POLYGONSCAN_API_KEY=your_polygonscan_key_here
OPTIMISM_ETHERSCAN_API_KEY=your_optimism_key_here
ARBISCAN_API_KEY=your_arbitrum_key_here
BASESCAN_API_KEY=your_base_key_here


# ─────────────────────────────────────────────
# Discord Notifications
# Create a webhook in your Discord channel and paste it here:
#   Server Settings → Integrations → Webhooks
# ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ─────────────────────────────────────────────
# Telegram Notifications
# 1. Create a bot: https://t.me/BotFather
# 2. Get your bot token
# 3. Get your chat_id:
#    - Add the bot to your group/channel
#    - Use https://api.telegram.org/bot<token>/getUpdates
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
